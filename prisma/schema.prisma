generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"   <-- remove or comment this
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Allocation {
  id              Int      @id @default(autoincrement())
  loan_number      String?  @db.Text
  case_id           Int?
  application_id    String?  @db.Text
  person_email       String?  @db.Text
  allocation_type    String?  @db.Text
  uploaded_by         String?  @db.Text
  active              Boolean?
  rule_id              Int?
  batch_id             Int?
  master_id            Int?
  co_code              String
  status               String?  @db.Text
  ho_code              String?  @db.Text
  zcm_code             String?  @db.Text
  created_at           DateTime?
  updated_at           DateTime?

  // Relations (exact table names)
  AllocationMaster AllocationMaster? @relation(fields: [master_id], references: [id])
  User             User              @relation(fields: [co_code], references: [employee_id])

  @@index([loan_number(length: 191), case_id])
  @@index([master_id])
  @@index([co_code])
}


model AllocationMaster {
  id                    Int      @id @default(autoincrement())
  type                  String
  active                Boolean?
  status                String?  @db.Text
  total_cases            Int?
  approved_by            String?  @db.Text
  rejected_by            String?  @db.Text
  fileName               String?  @db.Text
  remarks                String?  @db.Text
  successful_allocation  Int?
  failed_allocation      Int?
  uploaded_by             String?  @db.Text
  processing_time         String?  @db.Text
  created_at              DateTime?
  updated_at              DateTime?

  Allocation Allocation[]

  @@index([status(length: 191), active])
}


model AllocationRules {
  id              Int      @id @default(autoincrement())
  rule_type         String?  @db.Text
  description       String?  @db.Text
  name              String?  @db.Text
  active             Boolean? @default(true)
  enable             Boolean? @default(true)
  lastModifiedBy     String?  @db.Text
  assigned_to         String?  @db.Text
  created_at          DateTime?
  lastModified        DateTime?
    RuleConditions  RuleConditions[]

}


model BankBranchMaster {
  id               Int      @id @default(autoincrement())
  BANK_ID           Int?
  BANK_BRANCH_ID    Int?
  BANK_BRANCH_NAME  String?  @db.Text
  BRANCH_MICR_CODE  String?  @db.Text
  BRANCH_IFCS_CODE  String?  @db.Text
  ADDRESS_1          String?  @db.Text
  ADDRESS_2          String?  @db.Text
  ADDRESS_3          String?  @db.Text
  REGION_ID           Int?
  BRANCH_PINCODE      String?  @db.Text
  DISPLAY_VALUE       String?  @db.Text
  DISPLAY_ORDER        Int?
  CURRENT_STATUS       Int?
  status               Int?
  created_at            DateTime?
  updated_at            DateTime?

  bankmaster   bankmaster?   @relation(fields: [BANK_ID], references: [id])
  MasterRegion MasterRegion? @relation(fields: [REGION_ID], references: [id])

  @@index([BANK_ID])
  @@index([REGION_ID])
}


model bankmaster {
  id           Int      @id @default(autoincrement())
  bank_name     String?  @db.Text
  bank_id       String?  @db.Text
  display_name  String?  @db.Text
  created_at    DateTime @default(now())
  updated_at    DateTime

  BankBranchMaster BankBranchMaster[]
}


model BcpCollection {
  id          Int      @id @default(autoincrement())
  type         String?  @db.Text
  type_id       Int?
