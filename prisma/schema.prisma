}

model BranchMaster {
  id                 Int      @id @default(autoincrement())
  branch_name          String?  @db.Text
  collection_allowed    Boolean?
  collection_type        String?  @db.Text
  created_at              DateTime?
  updated_at              DateTime?
  bank_account_id          String?  @db.Text
